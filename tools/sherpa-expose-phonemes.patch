+const char *SherpaOnnxOfflineTtsPhonemizeWithEspeak(const char *text,
+                                                    const char *voice,
+                                                    const char *data_dir) {
+  if (!text) {
+    SHERPA_ONNX_LOGE("text is nullptr");
+    return nullptr;
+  }
+
+  if (!data_dir || !std::strlen(data_dir)) {
+    SHERPA_ONNX_LOGE("data_dir is nullptr or empty");
+    return nullptr;
+  }
+
+  try {
+    sherpa_onnx::InitEspeak(data_dir);
+
+    piper::eSpeakPhonemeConfig config;
+    if (voice && std::strlen(voice) > 0) {
+      config.voice = voice;
+    }
+
+    std::vector<std::vector<piper::Phoneme>> phonemes;
+    static std::mutex phonemize_mutex;
+    {
+      std::lock_guard<std::mutex> lock(phonemize_mutex);
+      piper::phonemize_eSpeak(text, config, phonemes);
+    }
+
+    std::string out = PhonemesToUtf8(phonemes);
+    char *ans = new char[out.size() + 1];
+    std::copy(out.begin(), out.end(), ans);
+    ans[out.size()] = '\0';
+    return ans;
+  } catch (const std::exception &e) {
+    SHERPA_ONNX_LOGE("Phonemize failed: %s", e.what());
+    return nullptr;
+  } catch (...) {
+    SHERPA_ONNX_LOGE("Phonemize failed with unknown error");
+    return nullptr;
+  }
+}
+
+void SherpaOnnxOfflineTtsFreePhonemes(const char *text) {
+  if (!text) {
+    return;
+  }
+  delete[] text;
+}
