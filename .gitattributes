# Normalize text files by default
* text=auto

# Scripts
*.sh text eol=lf
*.bat text eol=crlf

# Kotlin / Gradle / Native source files
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.cpp text eol=lf
*.cc text eol=lf
*.c text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
*.properties text eol=lf

# Keep Android assets byte-stable (avoid line-ending churn)
app/src/main/assets/** -text
